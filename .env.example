GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini/gemini-3.5-flash-lite
APP_ENV=development
LOG_LEVEL=INFO
CREWAI_TRACING_ENABLED=false
CREWAI_DISABLE_TELEMETRY=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DATABASE_URL=sqlite:///./stock_analyser.db
# Deployment: paste Neon's complete postgresql:// connection string instead.
# The backend automatically selects the psycopg 3 driver and preserves SSL options.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE_MINUTES=60
# Free-tier abuse protection (single server instance)
ANALYSIS_REQUESTS_PER_HOUR=5
ANALYSIS_IP_REQUESTS_PER_HOUR=10
BACKTEST_REQUESTS_PER_HOUR=20
REGISTRATION_REQUESTS_PER_HOUR=5
LOGIN_ATTEMPTS_PER_15_MINUTES=15
# Optional, auditable strategy tuning (defaults shown)
BUY_SCORE_MIN=2
SELL_SCORE_MAX=-2
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MEDIUM_RISK_VOLATILITY=20
HIGH_RISK_VOLATILITY=40
